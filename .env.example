# ==========================================
# PRIVATE STREAM RELAY - ENVIRONMENT CONFIG
# ==========================================

# 1. SERVER CONFIGURATION
NGINX_PORT=8080
BACKEND_PORT=3005
FRONTEND_PORT=3006

# The public URL you use to access the app (Must match the port above for local testing)
PUBLIC_APP_URL=http://localhost:8080

# 2. ADMIN CREDENTIALS
# You will use these to log into the dashboard
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234!!

# 3. SECURITY
# Secret key for sessions (Change this for production)
JWT_SECRET=this_is_a_very_secure_random_jwt_secret_key_998877

# 4. DATABASE CONFIGURATION (Fully isolated in Docker)
# These will be automatically used by the Postgres container
# and will NOT conflict with any databases on your Mac.
DB_USER=admin
DB_PASSWORD=docker_secret_db_pass_321
DB_NAME=stream_relay_db

# 5. STREAMING BEHAVIOR
# Automatically restart the last active stream if the server restarts
AUTO_RESUME_STREAM=true
